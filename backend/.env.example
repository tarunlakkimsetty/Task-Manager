# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5000

# JWT Configuration
# IMPORTANT: Use a strong, random secret key (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Database Configuration (Development Only)
# For local development with PostgreSQL
# NOTE: In production, use DATABASE_URL instead
DATABASE_URL=postgres://postgres:Postgresql@143@localhost:5432/task_manager

# Production Database (Railway)
# Replace with your Railway PostgreSQL URL
# DATABASE_URL=postgres://user:password@host:5432/dbname
